{
  "ConnectionStrings": {
    "ConnectionEnjoy": "Host=localhost;Port=5433;Database=enjoydb;Username=postgres;Password=password"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedIdentityRoles": true,
    "SeedDevelopmentUsers": true,
    "SeedDemoData": false,
    "DevelopmentUsers": [
      {
        "Name": "Admin",
        "Email": "admin@localhost.dev",
        "Password": "Admin123!",
        "Role": "Admin"
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowAnyOriginWhenEmpty": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5342" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
